RewriteEngine On
RewriteBase /

# ===== GZIP / Brotli Compression =====
<IfModule mod_deflate.c>
    # Force compression for mangled headers
    <IfModule mod_setenvif.c>
        <IfModule mod_headers.c>
            SetEnvIfNoCase ^(Accept-EncodXng|X-cept-Encoding|X{15}|~telerik\.telerik_ui|X-Middleton|X-Original-URL|X-Requested-With|~{15})$ ^((gzip|deflate)\s*,?\s*)+|[X~-]{4,13}$ HAVE_Accept-Encoding
            RequestHeader append Accept-Encoding "gzip,deflate" env=HAVE_Accept-Encoding
        </IfModule>
    </IfModule>

    # Compress all output labeled with one of the following MIME types
    AddOutputFilterByType DEFLATE text/plain
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/xml
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE text/javascript
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/x-javascript
    AddOutputFilterByType DEFLATE application/json
    AddOutputFilterByType DEFLATE application/ld+json
    AddOutputFilterByType DEFLATE application/xml
    AddOutputFilterByType DEFLATE application/xhtml+xml
    AddOutputFilterByType DEFLATE application/rss+xml
    AddOutputFilterByType DEFLATE application/atom+xml
    AddOutputFilterByType DEFLATE image/svg+xml
    AddOutputFilterByType DEFLATE image/x-icon
    AddOutputFilterByType DEFLATE application/vnd.ms-fontobject
    AddOutputFilterByType DEFLATE font/opentype
    AddOutputFilterByType DEFLATE font/otf
    AddOutputFilterByType DEFLATE font/ttf

    # Remove browser bugs for very old browsers
    BrowserMatch ^Mozilla/4 gzip-only-text/html
    BrowserMatch ^Mozilla/4\.0[678] no-gzip
    BrowserMatch \bMSIE !no-gzip !gzip-only-text/html
    Header append Vary Accept-Encoding
</IfModule>
# MIME type zorla ayarları - EN ÖNEMLİ KISIM
<IfModule mod_mime.c>
    # JavaScript dosyaları için
    AddType application/javascript .js
    AddType application/javascript .mjs
    AddType text/javascript .js
    
    # CSS dosyaları için
    AddType text/css .css
    
    # Diğer dosya türleri
    AddType text/html .html
    AddType application/json .json
    AddType image/svg+xml .svg
    AddType font/woff2 .woff2
    AddType font/woff .woff
    AddType font/ttf .ttf
    AddType image/png .png
    AddType image/jpg .jpg
    AddType image/jpeg .jpeg
    AddType image/gif .gif
    AddType image/webp .webp
    AddType image/vnd.microsoft.icon .ico
</IfModule>

# Header ayarları ile MIME type zorla - ÖZEL ASSETS KLASÖRÜ İÇİN
<IfModule mod_headers.c>
    # JavaScript dosyaları - hem kök hem de assets klasöründeki
    <FilesMatch "\.(js|mjs)$">
        Header always set Content-Type "application/javascript; charset=utf-8"
        Header always set X-Content-Type-Options nosniff
        Header always set Cache-Control "public, max-age=31536000"
    </FilesMatch>
    
    # Assets klasöründeki dosyalar için özel JS kural
    <Files "assets/*.js">
        Header always set Content-Type "application/javascript; charset=utf-8"
        Header always set X-Content-Type-Options nosniff
    </Files>
    
    # CSS dosyaları
    <FilesMatch "\.css$">
        Header always set Content-Type "text/css; charset=utf-8"
        Header always set Cache-Control "public, max-age=31536000"
    </FilesMatch>
    
    # Resim dosyaları
    <FilesMatch "\.(png|jpg|jpeg|gif|webp|ico|svg)$">
        Header always set Cache-Control "public, max-age=31536000"
    </FilesMatch>
    
    # Font dosyaları
    <FilesMatch "\.(woff|woff2|ttf|eot)$">
        Header always set Cache-Control "public, max-age=31536000"
        Header always set Access-Control-Allow-Origin "*"
    </FilesMatch>
</IfModule>

# Alternatif MIME type ayarları
RemoveType .js .css .html
AddType application/javascript .js
AddType text/css .css
AddType text/html .html

# Güvenlik başlıkları
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options nosniff
    Header always set X-Frame-Options SAMEORIGIN
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# Dizin görüntülemeyi engelle
Options -Indexes

# Specific blog post redirects
RewriteRule ^uzun-sure-cinsel-iliskiye-girmezseniz-ne-olur/?$ /blog/uzun-sure-cinsel-iliskiye-girmezseniz-ne-olur [R=301,L]

# Blog post redirects - redirect old URLs to /blog version
RewriteCond %{REQUEST_URI} !^/blog/
RewriteCond %{REQUEST_URI} !^/api/
RewriteCond %{REQUEST_URI} !^/assets/
RewriteCond %{REQUEST_URI} !^/(about|hakkimizda|iletisim|uzmanlar|uzmanlik|paketler|kampanyali-paket|kampanyali-premium-paket|indirimli-paket|psikolog-paketi|diyetisyen-paketi|fizyoterapist-paketi|aile-danismani-paketi|odeme|odeme-sayfasi|odeme-basarili|privacy|gizlilik-politikasi|disclosure-text|aydinlatma-metni|mesafeli-satis-sozlesmesi|visitor-consultant-agreement|ziyaretci-danisan-sozlesmesi|comment-rules|yorum-kurallari|anasayfa|giris-yap|test|test-al|test-sonuc|divan_paneli|doktor-paneli)
RewriteCond %{REQUEST_URI} !^/randevu-al/
RewriteCond %{REQUEST_URI} !^/yazilar/
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_URI} !\.(js|css|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot|json|xml)$
RewriteRule ^([^/]+)/?$ /blog/$1 [R=301,L]

# BirFatura API proxy routes
<IfModule mod_proxy.c>
  ProxyRequests Off
  ProxyPreserveHost On
  RewriteRule ^api/orderStatus/?$ https://irnfwewabogveofwemvg.supabase.co/functions/v1/birfatura-order-status [P,L]
  RewriteRule ^api/paymentMethods/?$ https://irnfwewabogveofwemvg.supabase.co/functions/v1/birfatura-payment-methods [P,L]
  RewriteRule ^api/orders/?$ https://irnfwewabogveofwemvg.supabase.co/functions/v1/birfatura-orders [P,L]
  RewriteRule ^api/orderCargoUpdate/?$ https://irnfwewabogveofwemvg.supabase.co/functions/v1/birfatura-order-cargo-update [P,L]
  RewriteRule ^api/invoiceLinkUpdate/?$ https://irnfwewabogveofwemvg.supabase.co/functions/v1/birfatura-invoice-link-update [P,L]
</IfModule>

<IfModule !mod_proxy.c>
  RedirectMatch 307 ^/api/orderStatus/?$ https://irnfwewabogveofwemvg.supabase.co/functions/v1/birfatura-order-status
  RedirectMatch 307 ^/api/paymentMethods/?$ https://irnfwewabogveofwemvg.supabase.co/functions/v1/birfatura-payment-methods
  RedirectMatch 307 ^/api/orders/?$ https://irnfwewabogveofwemvg.supabase.co/functions/v1/birfatura-orders
  RedirectMatch 307 ^/api/orderCargoUpdate/?$ https://irnfwewabogveofwemvg.supabase.co/functions/v1/birfatura-order-cargo-update
  RedirectMatch 307 ^/api/invoiceLinkUpdate/?$ https://irnfwewabogveofwemvg.supabase.co/functions/v1/birfatura-invoice-link-update
</IfModule>

# React Router için catch-all
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_URI} !^/assets/
RewriteCond %{REQUEST_URI} !^/api/
RewriteCond %{REQUEST_URI} !\.(js|css|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot|json|xml)$
RewriteRule ^(.*)$ /index.html [L,QSA]

# ErrorDocument overrides removed to preserve real 404/500 responses
# (prevents missing JS/CSS files from being rewritten to / and breaking the app)
